  "keyFeatures": [
    "Laravel-aware security scanning with project structure resolution",
    "Interactive terminal UI with real-time scan progress",
    "Four specialized scanners: env, config, dependency (live CVE lookup), and rules engine",
    "40 built-in YAML security rules covering secrets, injection, XSS, debug, crypto, and auth",
    "Custom rule support with regex, contains, and file-exists patterns",
    "Multiple output formats: JSON, SARIF, HTML, Markdown",
    "CI/CD integration with baseline support and fail-on thresholds",
    "Scan history with diff tracking between runs"
  ],
  "publicApiSurface": [
    "ward init - Initialize configuration directory",
    "ward scan <path> - Scan local Laravel project",
    "ward scan <git-url> - Clone and scan remote repository",
    "ward version - Print version information",
    "--output <formats> - Specify output formats (json,sarif,html,markdown)",
    "--fail-on <severity> - CI exit code control (info,low,medium,high,critical)",
    "--baseline <path> - Suppress known findings from baseline file",
    "--update-baseline <path> - Save current findings as new baseline",
    "config.yaml - Main configuration file",
    "rules/*.yaml - Custom security rules",
    "ENV-001 to ENV-008 - Environment scanner checks",
    "CONFIG-* - Configuration scanner checks",
    "Dependency scanner - Live CVE lookup via OSV.dev",
    "40 built-in rules across 7 categories"
  ]
}
